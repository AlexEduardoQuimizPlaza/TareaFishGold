<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarLiquidacion"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="Liquidación y Cierre de Faena"
        app:titleTextColor="@android:color/white" />

    <!-- Lista de liquidaciones registradas -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="3dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="@android:color/white">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Liquidaciones registradas"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#555555"
                android:layout_marginBottom="6dp" />

            <ListView
                android:id="@+id/lvLiquidaciones"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:divider="#EEEEEE"
                android:dividerHeight="1dp"
                android:background="#FAFAFA" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Formulario NUEVA LIQUIDACIÓN -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="3dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@android:color/white">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NUEVA LIQUIDACIÓN"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="?attr/colorPrimary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Para corregir un error, elimine la liquidación seleccionada en la lista y registre una nueva captura."
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="12dp" />

                <!-- Spinner planificaciones -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PLANIFICACIÓN A LIQUIDAR"
                    android:textSize="11sp"
                    android:textColor="#555555"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spPlanificacion"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="10dp" />

                <!-- Precio por Kg -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Precio por Kg ($)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPrecioPorKg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Peso capturado -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Peso Real Capturado (Kg)"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPesoCapturado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Monto estimado (auto-calculado) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MONTO ESTIMADO:"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvMontoEstimado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$ 0.00"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary" />
                </LinearLayout>

                <!-- Capitán responsable -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Capitán Responsable">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCapitanResponsable"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Observaciones -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Observaciones"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etObsLiquidacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="2" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Botón Finalizar y pagar -->
                <Button
                    android:id="@+id/btnFinalizarPagar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Finalizar y pagar"
                    android:backgroundTint="#00ACC1"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="16dp" />

                <!-- Botón Eliminar liquidación -->
                <Button
                    android:id="@+id/btnEliminarLiquidacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Eliminar liquidación seleccionada"
                    android:backgroundTint="#E53935"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="8dp"
                    android:enabled="false" />

            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
